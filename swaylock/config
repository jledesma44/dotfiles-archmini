ignore-empty-password
font="Arimo Nerd Font Propo"

clock
timestr=%R
datestr=%a, %e of %B

# Add current screenshot as wallpaper
# screenshots

# Add an image as a background
image=~/Pictures/wallpaper/lost-city.png

# Fade in time
fade-in=1

#Effect for bacground
effect-blur=20x6
#effect-greyscale
#effect-pixalate=5

#Show/Hide indicator
indicator

#Indicator size
indicator-radius=200

indicator-thickness=10
indicator-caps-lock

#Define all colors

key-hl-color=00000066
separator-color=00000000

inside-color=00000033
